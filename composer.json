{
  "name": "resofire/blog-cards",
  "description": "Display the discussion list as blog-style cards",
  "type": "flarum-extension",
  "keywords": [
    "flarum",
    "extension",
    "discussion",
    "cards",
    "blog"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Resofire"
    }
  ],
  "require": {
    "flarum/core": "^2.0",
    "flarum/tags": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Resofire\\BlogCards\\": "src/"
    }
  },
  "extra": {
    "flarum-extension": {
      "title": "Blog Cards",
      "category": "feature",
      "icon": {
        "name": "fas fa-border-all",
        "backgroundColor": "#69c6b9",
        "color": "#1a2744"
      }
    }
  },
  "support": {
    "issues": "https://github.com/resofire/blog-cards/issues"
  }
}
